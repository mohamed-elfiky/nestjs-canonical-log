{
  "compilerOptions": {
    "module": "node16",
    "target": "es2019",
    "moduleResolution": "node16",
    "declaration": true,
    "declarationMap": true,
    "removeComments": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["./src"]
}

{
  "name": "nestjs-canonical-log",
  "version": "0.1.0",
  "description": "Stripe-style canonical log lines for NestJS — one structured line per HTTP request",
  "keywords": [
    "nestjs",
    "logging",
    "pino",
    "datadog",
    "observability",
    "canonical-log"
  ],
  "license": "MIT",
  "author": "Mohamed Elfiky <elfikymohamedelfiky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohamed-elfiky/nestjs-canonical-log.git"
  },
  "bugs": {
    "url": "https://github.com/mohamed-elfiky/nestjs-canonical-log/issues"
  },
  "homepage": "https://github.com/mohamed-elfiky/nestjs-canonical-log#readme",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.adapter.d.ts",
      "default": "./dist/adapters/fastify.adapter.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --watch --build tsconfig.build.json",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run type-check && npm run test && npm run build",
    "bench": "ts-node --project tsconfig.bench.json --transpile-only benchmarks/overhead.ts",
    "bench:profile": "TS_NODE_PROJECT=tsconfig.bench.json 0x --output-dir benchmarks/.flamegraph -- node --require ts-node/register/transpile-only benchmarks/profile-canonical.ts",
    "preversion": "npm run check",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "nestjs-cls": "^4.0.0",
    "nestjs-pino": "^3.0.0 || ^4.0.0",
    "reflect-metadata": "^0.1.0 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "0x": "^6.0.0",
    "@nestjs/common": "10.2.10",
    "@nestjs/core": "10.2.10",
    "@nestjs/platform-express": "10.2.10",
    "@nestjs/platform-fastify": "^10.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "autocannon": "^8.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "nestjs-cls": "^4.3.0",
    "nestjs-pino": "^3.5.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.0.0"
  }
}

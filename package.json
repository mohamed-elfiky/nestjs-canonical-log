{
  "name": "nestjs-canonical-log",
  "version": "0.1.0",
  "description": "Stripe-style canonical log lines for NestJS — one structured line per HTTP request",
  "keywords": [
    "nestjs",
    "logging",
    "pino",
    "datadog",
    "observability",
    "canonical-log"
  ],
  "license": "MIT",
  "author": "Mohamed Elfiky <elfikymohamedelfiky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohamed-elfiky/nestjs-canonical-log.git"
  },
  "bugs": {
    "url": "https://github.com/mohamed-elfiky/nestjs-canonical-log/issues"
  },
  "homepage": "https://github.com/mohamed-elfiky/nestjs-canonical-log#readme",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "tsc --watch --build tsconfig.build.json",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "check": "npm run type-check && npm run test && npm run build",
    "preversion": "npm run check",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "nestjs-cls": "^4.0.0",
    "nestjs-pino": "^3.0.0 || ^4.0.0",
    "reflect-metadata": "^0.1.0 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "10.2.10",
    "@nestjs/core": "10.2.10",
    "@nestjs/platform-express": "10.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nestjs-cls": "^4.3.0",
    "nestjs-pino": "^3.5.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.0"
  }
}
